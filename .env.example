# ── Contact Form ─────────────────────────────────────────────────────────────
# Get a free API key at https://resend.com
# Add this in Vercel → Project → Settings → Environment Variables
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Site URL ──────────────────────────────────────────────────────────────────
# Your deployed Vercel URL (no trailing slash). Used for OG image meta tags.
# Vercel sets VERCEL_URL automatically, but NEXT_PUBLIC_SITE_URL lets you
# use a custom domain once you have one.
NEXT_PUBLIC_SITE_URL=https://victorgooge.vercel.app
